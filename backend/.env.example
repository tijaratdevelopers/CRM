PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Publicly reachable URL for this backend (e.g. an ngrok/production domain).
# Only used to show the correct Meta webhook URL on the Settings > Integrations page.
PUBLIC_BACKEND_URL=http://localhost:4000

# Supabase project settings (Project Settings -> API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Meta Graph API — Lead Ads webhook.
# 1) Create a Meta App -> add the "Webhooks" + "Lead Ads" products.
# 2) Set the webhook callback URL to {PUBLIC_BACKEND_URL}/api/meta/webhook,
#    subscribe to the "leadgen" field, and use META_VERIFY_TOKEN below as the verify token.
# 3) Generate a Page Access Token with the leads_retrieval + pages_show_list permissions.
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=change-me-verify-token
META_PAGE_ACCESS_TOKEN=

# WhatsApp Business Cloud API (stubbed until you have real credentials)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=change-me-verify-token

# Resend (https://resend.com/api-keys) — used to send invite emails when a
# team lead or staff account is created.
RESEND_API_KEY=
# Defaults to Resend's shared onboarding@resend.dev sender if unset. Switch
# to an address on your own verified domain once one is set up.
EMAIL_FROM=
EMAIL_REPLY_TO=
